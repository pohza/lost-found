PORT=3000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=lostfound
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:5173
JSON_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# Password reset: full URL of the SPA (for links in email), e.g. https://your-domain.com
APP_PUBLIC_URL=http://localhost:8080
# Set to true only in dev to get debugResetLink in JSON (never in production)
PASSWORD_RESET_RETURN_LINK=false
# Optional SMTP (if unset, server logs reset URL in non-production)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
